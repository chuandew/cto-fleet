#!/usr/bin/env bash
# cto-fleet-config — simple YAML config reader/writer
#
# Usage:
#   cto-fleet-config get <key>
#   cto-fleet-config set <key> <value>
#   cto-fleet-config list
set -euo pipefail

CONFIG_FILE="${CTO_FLEET_STATE_DIR:-$HOME/.cto-fleet}/config.yaml"

ensure_config() {
  local dir
  dir="$(dirname "$CONFIG_FILE")"
  mkdir -p "$dir"
  chmod 700 "$dir" 2>/dev/null || true
  if [ ! -f "$CONFIG_FILE" ]; then
    touch "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE" 2>/dev/null || true
  fi
}

cmd="${1:-}"
case "$cmd" in
  get)
    key="${2:-}"
    [ -z "$key" ] && exit 1
    [ -f "$CONFIG_FILE" ] || exit 0
    awk -v k="$key" '$1 == k":" {print $2}' "$CONFIG_FILE"
    ;;
  set)
    key="${2:-}"
    value="${3:-}"
    [ -z "$key" ] && { echo "Usage: cto-fleet-config set <key> <value>" >&2; exit 1; }
    ensure_config
    if grep -q "^${key}:" "$CONFIG_FILE" 2>/dev/null; then
      # Use awk to avoid sed injection via special characters in key/value
      awk -v k="$key" -v v="$value" '{if ($0 ~ "^"k":") print k": "v; else print}' \
        "$CONFIG_FILE" > "$CONFIG_FILE.tmp" && mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"
      chmod 600 "$CONFIG_FILE" 2>/dev/null || true
    else
      echo "${key}: ${value}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    [ -f "$CONFIG_FILE" ] && cat "$CONFIG_FILE" || true
    ;;
  *)
    echo "Usage: cto-fleet-config {get|set|list}" >&2
    exit 1
    ;;
esac
